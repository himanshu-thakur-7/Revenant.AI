# ─────────────────────────────────────────────────────────────
# Revenant.AI — environment template
# Copy to `.env` and fill in. The pipeline runs in OFFLINE mode
# (canned fixtures) when keys are missing, so you can develop the
# whole flow before wiring a single credential.
# ─────────────────────────────────────────────────────────────

# Master switches
REVENANT_MODE=offline          # offline | live   (offline = fixtures, no network)
DRY_RUN=1                       # 1 = never actually send email

# Orchestration model (Hermes / Nous Portal, OpenAI, or any OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# OpenAI (codegen, copy, embeddings, TTS fallback)
OPENAI_API_KEY=

# Linkup (web recon / search)
LINKUP_API_KEY=

# ElevenLabs (voice memo + walkthrough narration + convo agent)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=              # a voice you own / have consent for
ELEVENLABS_AGENT_ID=              # pre-built conversational agent (the live prototype)

# Cloudflare (Pages Direct Upload + Stream + Workers AI)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=revenant-sites

# Convex (truth ledger + realtime console)
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Razorpay (test mode — book a paid pilot)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
FROM_EMAIL=founder@revenant.ai

# Telegram (Hermes gateway — founder control + HITL alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stage-1b classifier provider for the gate (Addendum 002 §3)
STAGE1B_PROVIDER=openai           # openai | cloudflare | offline
