<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ seller.name }} × {{ lead.company_name }} — a working prototype</title>
  <meta name="description" content="{{ seller.one_liner }}" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root { color-scheme: dark; --wisp:#52e0c4; --ember:#f5a623; }
    * { font-family: 'Space Grotesk', system-ui, sans-serif; }
    body {
      background:
        radial-gradient(900px 600px at 80% -10%, rgba(82,224,196,.12), transparent 60%),
        radial-gradient(700px 500px at 0% 100%, rgba(245,166,35,.06), transparent 55%),
        #06070d;
      min-height: 100vh;
    }
    .glow { box-shadow: 0 0 90px -20px rgba(82,224,196,.45); }
    .cite { font-size:.72rem; color:var(--wisp); font-style:italic; font-family:'JetBrains Mono',monospace; }
    .mono { font-family:'JetBrains Mono', monospace; }
    .grad { background:linear-gradient(180deg,#fff 0%,#cfe9e2 60%,var(--wisp) 100%); -webkit-background-clip:text; background-clip:text; color:transparent; }
    @keyframes rise { from {opacity:0; transform:translateY(14px)} to {opacity:1; transform:none} }
    .rise { animation: rise .7s ease both; }
    .rise:nth-child(2){animation-delay:.08s} .rise:nth-child(3){animation-delay:.16s}
  </style>
</head>
<body class="text-slate-100 antialiased">
  <!-- anonymized engagement beacon (copy / CTA / play) -->
  <script>
    window.__revenant = { campaign: "{{ campaign_id }}" };
    function beacon(ev){ try{ navigator.sendBeacon("{{ beacon_url }}", JSON.stringify({c:"{{ campaign_id }}",e:ev,t:Date.now()})); }catch(_){} }
    window.addEventListener("load", ()=>beacon("view"));
  </script>

  <main class="max-w-3xl mx-auto px-6 py-16">
    <!-- Hero -->
    <section class="rise">
      <p class="mono text-xs mb-4" style="color:var(--wisp)">◆ built for {{ lead.company_name }} · {{ ts }}</p>
      <h1 class="grad text-4xl md:text-6xl font-bold tracking-tight leading-[1.05]">
        {{ headline }}
      </h1>
      <p class="mt-6 text-lg text-slate-300 max-w-2xl">{{ subhead }}</p>
    </section>

    <!-- The pain, in their own words -->
    <section class="mt-12 rise">
      <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-3">What we noticed</h2>
      <blockquote class="pl-5 py-3 text-slate-200 italic bg-white/5 rounded-r-lg" style="border-left:3px solid var(--wisp)">
        “{{ pain_quote }}”
        {% if pain_citation %}<div class="cite mt-2">— {{ pain_citation }}</div>{% endif %}
      </blockquote>
    </section>

    <!-- The agent-recorded walkthrough (Loom-style) -->
    {% if walkthrough_url %}
    <section class="mt-12 rise">
      <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-3">
        A 60-second walkthrough — recorded by an AI, not a human
      </h2>
      <div class="rounded-xl overflow-hidden glow border border-white/10 aspect-video">
        <iframe src="{{ walkthrough_url }}" class="w-full h-full" allow="autoplay; fullscreen"
          onclick="beacon('play_video')"></iframe>
      </div>
    </section>
    {% endif %}

    <!-- The working prototype -->
    <section class="mt-12 rise">
      <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-3">The prototype, live</h2>
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        {{ prototype_html | safe }}
      </div>
      {% if prototype_citation %}<div class="cite mt-2">{{ prototype_citation }}</div>{% endif %}
    </section>

    <!-- Voice memo -->
    {% if voice_url %}
    <section class="mt-12 rise">
      <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-3">A note for you</h2>
      <audio controls preload="none" class="w-full" onplay="beacon('play_audio')">
        <source src="{{ voice_url }}" type="audio/mpeg" />
      </audio>
    </section>
    {% endif %}

    <!-- CTA: book a paid pilot (Razorpay) -->
    <section class="mt-16 rise text-center">
      <a href="{{ payment_link }}" onclick="beacon('cta_click')"
         class="inline-block transition font-semibold px-9 py-4 rounded-xl glow"
         style="background:linear-gradient(135deg,var(--wisp),#34b8a0);color:#04120e">
        Book a paid pilot — ₹{{ pilot_price }}
      </a>
      <p class="mt-4 text-sm text-slate-500">
        {{ seller.value_prop }}
      </p>
    </section>

    <footer class="mt-20 pt-8 border-t border-white/10 text-xs text-slate-600">
      <p>Prototype auto-generated by {{ seller.name }} via Revenant. Every claim above cites a
         public source. Not affiliated with or endorsed by {{ lead.company_name }}.</p>
      <p class="mt-2">Reply STOP to opt out · {{ seller.name }}, built with Revenant.AI</p>
    </footer>
  </main>
</body>
</html>
